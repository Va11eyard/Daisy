{
  "name": "daisy-anti-hallucination-layers",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "TypeScript implementation of Daisy's 5-layer anti-hallucination pipeline + dataset-generation pipeline. See docs/Anti-Hallucination Spec.md.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:typecheck": "tsc -p tsconfig.scripts.json --noEmit",
    "build:tasks": "node --loader ts-node/esm scripts/build_task_prompts.ts",
    "validate": "node --loader ts-node/esm scripts/run_validation.ts",
    "merge": "node --loader ts-node/esm scripts/final_merge.ts"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "franc-min": "^6.2.0",
    "sharp": "^0.34.5",
    "tiktoken": "^1.0.22",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "overrides": {
      "sharp": "npm:sharp@0.32.6"
    }
  }
}
